exports[`LoadTestDetail (mode-adaptive) > iterations 1`] = `"<div class="flex flex-col h-full bg-background"><div class="border-b bg-card px-6 py-4"><div class="flex items-center gap-3 bg-muted/50 p-3 mb-3"><div data-slot="badge" class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 text-foreground font-mono font-bold shrink-0">GET</div><span class="truncate text-sm font-mono text-foreground flex-1">http://127.0.0.1:8080/x</span></div><div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm mb-3 p-3 border rounded-md bg-background/50"><div class="flex items-center gap-2 text-muted-foreground"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings2 lucide-settings-2 w-4 h-4 shrink-0" aria-hidden="true"><path d="M14 17H5"></path><path d="M19 7h-9"></path><circle cx="17" cy="17" r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg><span class="font-medium">Test config</span></div><div class="flex items-center gap-2"><span class="text-muted-foreground">Mode:</span><span class="text-foreground capitalize">Fixed Iterations</span></div><div class="flex items-center gap-2"><span class="text-muted-foreground">Duration:</span><span class="text-foreground font-mono">3s</span></div><div class="flex items-center gap-2"><span class="text-muted-foreground">Concurrency:</span><span class="text-foreground font-mono">20</span></div></div><div class="grid grid-cols-3 gap-3"><div class="bg-muted/50 p-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up w-4 h-4 text-purple-500" aria-hidden="true"><path d="M16 7h6v6"><